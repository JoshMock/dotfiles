#!/usr/bin/env python3

import subprocess
import random
import sys


def parse_duration(time_str):
    """Parse a mm:ss or h:mm:ss duration string into total seconds."""
    parts = time_str.strip().split(":")
    return sum(int(p) * 60 ** i for i, p in enumerate(reversed(parts)))


def get_queue_remaining_seconds():
    """Return the number of seconds remaining in the current Mopidy queue.

    Sums all track durations from the queue, then subtracts the elapsed time
    of the currently playing track.
    """
    try:
        # Sum all track durations in the queue
        playlist = subprocess.run(
            ["mpc", "-h", "::", "playlist", "-f", "%time%"],
            capture_output=True, text=True, check=True,
        )
        total = sum(
            parse_duration(line)
            for line in playlist.stdout.splitlines()
            if line.strip()
        )

        # Subtract elapsed time of current track (status line: "2:01/6:13 (32%)")
        status = subprocess.run(
            ["mpc", "-h", "::"],
            capture_output=True, text=True, check=True,
        )
        for line in status.stdout.splitlines():
            # The progress line contains a '/' separating elapsed/total
            if "/" in line and "%" in line:
                elapsed_str = line.split()[2].split("/")[0]
                total -= parse_duration(elapsed_str)
                break

        return max(total, 0)
    except (subprocess.CalledProcessError, FileNotFoundError, ValueError):
        return 0


def get_random_album():
    """Get a random locally-available album from the beet library.

    Queries only tracks present on this machine (annex:local). 50% of the time
    the query is further narrowed to genre:ambient.
    """
    extra_filters = []
    if random.random() < 0.5:
        extra_filters.append("genre:ambient")

    query_args = ["annex:local"] + extra_filters

    try:
        result = subprocess.run(
            ["beet", "ls", "-a", "-f", "$albumartist|$album|$year"] + query_args,
            capture_output=True,
            text=True,
            check=True,
        )
        albums = []
        for line in result.stdout.strip().split("\n"):
            if line.strip():
                parts = line.strip().split("|")
                if len(parts) >= 3:
                    albums.append(
                        {
                            "albumartist": parts[0],
                            "album": parts[1],
                            "year": parts[2],
                        }
                    )
        if not albums:
            return None
        return random.choice(albums)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def play_album(album_data):
    """Queue an album via beet play."""
    try:
        result = subprocess.run(
            [
                "beet",
                "play",
                "-a",
                f"albumartist:{album_data['albumartist']}",
                f"album:{album_data['album']}",
            ],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.returncode == 0
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False


def check_playing_status():
    """Return True if playerctl reports a Playing state."""
    try:
        result = subprocess.run(
            ["playerctl", "status"], capture_output=True, text=True, check=True
        )
        return result.stdout.strip() == "Playing"
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False


def main():
    """Main script logic."""
    if not check_playing_status():
        print("Not playing. Exiting.")
        return 0

    remaining_seconds = get_queue_remaining_seconds()
    remaining_minutes = remaining_seconds / 60
    print(f"Queue has {remaining_minutes:.1f} minutes remaining")

    if remaining_minutes >= 15:
        print("Queue has sufficient time remaining. Exiting.")
        return 0

    print("Queue has less than 15 minutes remaining. Selecting random album...")

    album = get_random_album()
    if not album:
        print("Error: Could not get random album from beet.")
        return 1

    print(f"Selected album: {album['albumartist']} - {album['album']} ({album['year']})")

    print(f"Queuing album '{album['albumartist']} - {album['album']}'...")
    if not play_album(album):
        print(f"Error: Failed to queue album '{album['albumartist']} - {album['album']}'")
        return 1

    print(f"OK queued '{album['albumartist']} - {album['album']}'")
    return 0


if __name__ == "__main__":
    sys.exit(main())