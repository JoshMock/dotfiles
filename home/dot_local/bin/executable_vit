#!/usr/bin/env bash
exec podman run --rm -i \
    $([ -t 0 ] && echo "-t") \
    --userns=keep-id \
    --network=host \
    -v "$HOME:$HOME:z" \
    -e HOME="$HOME" \
    -e TERM=xterm-256color \
    -e TASKRC="$HOME/.taskrc" \
    -e TASKDATA="$HOME/.task" \
    -e DBUS_SESSION_BUS_ADDRESS="$DBUS_SESSION_BUS_ADDRESS" \
    -v /run/user/"$(id -u)":/run/user/"$(id -u)":z \
    -w "$PWD" \
    localhost/vit vit "$@"
