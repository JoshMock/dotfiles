FROM debian:bookworm-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends git-annex python3 python3-pip ffmpeg mpc playerctl \
    && rm -rf /var/lib/apt/lists/*
RUN pip3 install --no-cache-dir --break-system-packages 'beets[lastgenre,fetchart]==2.5.1'
COPY Code/beets-git-annex/ /tmp/beets-git-annex/
RUN pip3 install --no-cache-dir --break-system-packages /tmp/beets-git-annex/
